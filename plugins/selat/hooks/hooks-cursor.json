{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "./hooks-handlers/run-hook.cmd ensure-runner.sh",
        "timeout": 120
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./hooks-handlers/run-hook.cmd auto-approve-selat-cursor.sh",
        "matcher": "selat",
        "timeout": 5
      }
    ]
  }
}
